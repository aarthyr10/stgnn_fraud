# =====================================================================
# stgnn_fraud · environment template
# =====================================================================
# Copy this file to `.env` (same directory) and fill in / uncomment any
# of the values you want to override. main.py reads `.env` at startup
# via python-dotenv, so all values below feed straight into os.environ.
# Unset values fall back to the defaults documented in the README.
# =====================================================================

# ------------------------------------------------ Data paths

# Directory containing the three real Elliptic CSVs:
#   elliptic_txs_features.csv   (203,769 rows × 167 cols, no header)
#   elliptic_txs_edgelist.csv   (234,355 rows × 2 cols, with header)
#   elliptic_txs_classes.csv    (203,769 rows × 2 cols, with header)
# Leave blank to use the synthetic demo dataset.
# STGNN_DATA_DIR=data/elliptic

# Pickled PyG Data object cached after the first CSV parse.
# STGNN_GRAPH_CACHE=artefacts/graph.pkl

# ------------------------------------------------ Model artefact paths

# Frozen spatial subnet (saved by training/train_gcn.py)
# STGNN_GCN_PATH=artefacts/gcn_subnet.pt

# Temporal head (saved by training/train_gru.py)
# STGNN_HYBRID_PATH=artefacts/gru_head.pt

# TGAT legacy baseline (optional; not on the headline comparison path)
# STGNN_TGAT_PATH=artefacts/tgat.pt

# Random Forest reference (Maganti 2026 baseline)
# STGNN_RF_PATH=artefacts/rf_baseline.pkl

# Per-(node, timestep) frozen-GCN embeddings (output of
# training/precompute_embeddings.py)
# STGNN_EMBED_PATH=artefacts/embeddings.parquet

# Five-condition evaluation table consumed by the Compare tab.
# STGNN_METRICS_PATH=artefacts/metrics.json

# Append-only history log; one JSON object per pipeline run.
# STGNN_HISTORY_PATH=artefacts/run_history.jsonl

# ------------------------------------------------ Runtime

# Log level for the Python root logger. INFO is the default; DEBUG
# surfaces per-iteration EM convergence and per-stage timing.
# LOG_LEVEL=INFO
